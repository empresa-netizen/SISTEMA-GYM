<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory suffix="Test.php">./tests/Feature</directory>
        </testsuite>
        <testsuite name="ApiV1">
            <directory suffix="Test.php">./tests/Feature/Api/V1</directory>
        </testsuite>
        <testsuite name="BusinessLogic">
            <directory suffix="Test.php">./tests/Feature/BusinessLogic</directory>
        </testsuite>
    </testsuites>
    <coverage>
        <report>
            <html outputDirectory="tests/coverage/html"/>
            <text outputFile="tests/coverage/coverage.txt"/>
        </report>
    </coverage>
    <source>
        <include>
            <directory suffix=".php">./app</directory>
        </include>
    </source>
    <php>
        <server name="APP_ENV" value="testing"/>
        <server name="BCRYPT_ROUNDS" value="4"/>
        <server name="CACHE_DRIVER" value="array"/>
        <server name="MAIL_MAILER" value="array"/>
        <server name="QUEUE_CONNECTION" value="sync"/>
        <server name="SESSION_DRIVER" value="array"/>
        <server name="BROADCAST_DRIVER" value="log"/>
        <server name="TELESCOPE_ENABLED" value="false"/>
        <!-- Banco dedicado: NÃO usa o MySQL de desenvolvimento (mazer) -->
        <server name="DB_CONNECTION" value="mysql"/>
        <server name="DB_HOST" value="db"/>
        <server name="DB_PORT" value="3306"/>
        <server name="DB_DATABASE" value="mazer_testing"/>
        <server name="DB_USERNAME" value="mazer"/>
        <server name="DB_PASSWORD" value="root"/>
    </php>
</phpunit>
