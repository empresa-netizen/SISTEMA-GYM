# =============================================================================
# MGTEAM / SISTEMA-GYM — Environment template
# Copy to .env and fill values. NEVER commit real secrets.
# =============================================================================

# --- Application (PRODUCTION: APP_ENV=production, APP_DEBUG=false) ---
APP_NAME="MGTEAM FITNESS & HEALTH"
APP_ENV=local
APP_KEY=
# Generate with: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stack
LOG_LEVEL=debug
# Production tip: LOG_LEVEL=warning

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mgteam
DB_USERNAME=mgteam
DB_PASSWORD=

# --- Cache / Queue / Session ---
# Local MVP: file + database. Production scale: redis for both.
BROADCAST_DRIVER=reverb
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (required for queued Jobs: SendPaymentReminderEmail, etc.) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Laravel Sanctum (API mobile / SPA) ---
# Domains that may use cookie-based SPA auth (comma-separated). Bearer tokens work without this.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,plataforma.mgteamoficial.site
# Production: adicionar o domínio real, ex. plataforma.mgteamoficial.site
# Optional: minutes until personal access tokens expire (null = never)
# SANCTUM_TOKEN_EXPIRATION=

# --- Payment Gateways (placeholders only — set real keys in server secrets) ---
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# --- Object storage (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Realtime (Laravel Reverb) ---
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Legacy Pusher placeholders (unused when BROADCAST_DRIVER=reverb)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Observability (Sentry) ---
# Create a project at https://sentry.io/ and paste the Laravel DSN below.
# Leave empty locally to disable reporting. REQUIRED in production for Dia 1.
SENTRY_LARAVEL_DSN=
# Optional aliases / tuning
# SENTRY_DSN=                 # fallback if SENTRY_LARAVEL_DSN empty
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
# Browser SDK uses the same DSN via config('sentry.dsn') in Blade.

# =============================================================================
# Production checklist
# - APP_ENV=production
# - APP_DEBUG=false
# - Strong APP_KEY and DB_PASSWORD
# - Real SMTP credentials (Jobs de e-mail)
# - QUEUE_CONNECTION=database|redis + Supervisor running queue:work
# - SENTRY_LARAVEL_DSN set + alert to Slack/Discord
# - Smoke: GET /api/v1/debug-sentry (Bearer) → event no painel Sentry
# - After deploy: ./deploy.sh
# =============================================================================
