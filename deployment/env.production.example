# =============================================================================
# Produção — plataforma.mgteamoficial.site
# Copie para .env no servidor. NUNCA commitar este arquivo com valores reais.
# =============================================================================

APP_NAME="MGTEAM FITNESS & HEALTH"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://plataforma.mgteamoficial.site
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mgteamoficial.site
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=plataforma.mgteamoficial.site,www.plataforma.mgteamoficial.site

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENVIRONMENT=production

FILESYSTEM_DISK=public
